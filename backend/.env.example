# ==================== 服务器配置 ====================
PORT=3002
NODE_ENV=production

# ==================== JWT 密钥配置 ====================
# ⚠️ 生产环境必须使用强随机密钥
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ==================== 管理员初始密码 ====================
# ⚠️ 首次部署时设置强密码
INITIAL_ADMIN_PASSWORD=

# ==================== 相册密码 ====================
ALBUM_PASSWORD=

# ==================== CORS 配置 ====================
# 改为你的实际域名
CORS_ORIGIN=https://yourdomain.com

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
